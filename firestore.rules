rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the request is from an authenticated admin
    function isAdmin() {
      return request.auth != null;
    }

    // Contacts (leads) form submissions
    match /contacts/{document} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Bookings consultations
    match /bookings/{document} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Public content collections (Read-only for public, Full access for admin)
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /demos/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /features/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /faqs/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pricing/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
